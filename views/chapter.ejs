<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= chapter.title %> | TextToLearn</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">

    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,0,0"
        rel="stylesheet">

    <script>

        tailwind.config = {

            theme: {

                extend: {

                    fontFamily: {

                        sans: ["Inter", "sans-serif"]

                    }

                }

            }

        }

    </script>

</head>

<body class="bg-[#DFD0B8] font-sans text-[#222831]">

<div class="flex min-h-screen">

    <%- include("partials/sidebar") %>

    <main class="flex-1 overflow-y-auto">

        <div class="mx-auto max-w-7xl px-8 py-10">

            <div class="grid gap-8 xl:grid-cols-[1fr_260px]">

                <div>

                    <a
                        href="/course/<%= course._id %>"
                        class="inline-flex items-center gap-2 rounded-full border border-[#948979]/30 bg-[#F7F3EC] px-5 py-2 text-sm font-semibold text-[#393E46] transition hover:bg-[#393E46] hover:text-[#DFD0B8]">

                        <span class="material-symbols-rounded">

                            arrow_back

                        </span>

                        Back to Course

                    </a>

                    <div class="mt-6 rounded-3xl border border-[#948979]/25 bg-[#F7F3EC] p-8 shadow-sm">

                        <div class="flex flex-wrap items-center justify-between gap-6">

                            <div>

                                <div class="mb-4 flex flex-wrap gap-3">

                                    <span class="rounded-full bg-[#393E46] px-4 py-2 text-sm font-semibold text-[#DFD0B8]">

                                        Module <%= Number(moduleIndex)+1 %>

                                    </span>

                                    <span class="rounded-full bg-[#948979] px-4 py-2 text-sm font-semibold text-white">

                                        Chapter <%= Number(chapterIndex)+1 %>

                                    </span>

                                </div>

                                <h1 class="text-5xl font-black tracking-tight text-[#222831]">

                                    <%= chapter.title %>

                                </h1>

                            </div>

                        </div>

                    </div>

                    <section
                        id="lesson"
                        class="mt-8 rounded-3xl border border-[#948979]/25 bg-[#F7F3EC] p-8 shadow-sm">

                        <div class="mb-8 flex items-center gap-4">

                            <div
                                class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[#393E46]">

                                <span class="material-symbols-rounded text-3xl text-white">

                                    menu_book

                                </span>

                            </div>

                            <div>

                                <h2 class="text-3xl font-bold">

                                    Lesson

                                </h2>

                                <p class="mt-1 text-[#948979]">

                                    Read carefully before solving the practice problems.

                                </p>

                            </div>

                        </div>

                        <% chapter.blocks.forEach(block=>{ %>

                            <% if(block.type==="text"){ %>

<div class="mb-8 rounded-2xl border border-[#948979]/20 bg-white p-7 leading-8 text-[#393E46] shadow-sm">

    <p class="whitespace-pre-line text-[17px]">

        <%= block.content %>

    </p>

</div>

<% } %>

<% if(block.type==="code"){ %>

<div class="mb-8 overflow-hidden rounded-2xl shadow-lg">

    <div class="flex items-center justify-between bg-[#222831] px-6 py-4">

        <div class="flex items-center gap-2">

            <div class="h-3 w-3 rounded-full bg-red-400"></div>

            <div class="h-3 w-3 rounded-full bg-yellow-400"></div>

            <div class="h-3 w-3 rounded-full bg-green-400"></div>

        </div>

        <span class="font-mono text-sm font-semibold uppercase tracking-wide text-gray-300">

            <%= block.language %>

        </span>

        <button
            class="rounded-lg border border-gray-600 px-3 py-1 text-sm text-gray-300 transition hover:bg-gray-700">

            Copy

        </button>

    </div>

    <pre class="overflow-x-auto bg-[#222831] p-6 text-[15px] leading-7 text-gray-100"><code><%= block.content %></code></pre>

</div>

<% } %>

<% }) %>

</section>
<% if(chapter.practiceQuestions.length){ %>

<section
    id="practice"
    class="mt-8 rounded-3xl border border-[#948979]/25 bg-[#F7F3EC] p-8 shadow-sm">

    <div class="mb-8 flex items-center gap-4">

        <div
            class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[#393E46]">

            <span class="material-symbols-rounded text-3xl text-white">

                assignment

            </span>

        </div>

        <div>

            <h2 class="text-3xl font-bold">

                Practice Problems

            </h2>

            <p class="mt-1 text-[#948979]">

                Solve these before moving to the next chapter.

            </p>

        </div>

    </div>

    <div class="grid gap-6 md:grid-cols-2">

        <% chapter.practiceQuestions.forEach(question=>{ %>

        <a
            href="<%= question.url %>"
            target="_blank"
            class="group rounded-2xl border border-[#948979]/20 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-[#393E46] hover:shadow-xl">

            <div class="flex items-center justify-between">

                <span
                    class="rounded-full bg-[#393E46] px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">

                    <%= question.platform %>

                </span>

                <span
                    class="rounded-full bg-[#DFD0B8] px-3 py-1 text-xs font-semibold text-[#393E46]">

                    <%= question.difficulty %>

                </span>

            </div>

            <h3 class="mt-5 text-xl font-bold text-[#222831]">

                <%= question.title %>

            </h3>

            <div class="mt-8 flex items-center justify-between">

                <span class="font-semibold text-[#393E46]">

                    Solve Problem

                </span>

                <span
                    class="material-symbols-rounded transition-transform duration-300 group-hover:translate-x-2">

                    arrow_forward

                </span>

            </div>

        </a>

        <% }) %>

    </div>

</section>

<% } %>

<% if(chapter.youtubeVideo){ %>

<section
    id="video"
    class="mt-8 rounded-3xl border border-[#948979]/25 bg-[#F7F3EC] p-8 shadow-sm">

    <div class="mb-8 flex items-center gap-4">

        <div
            class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[#393E46]">

            <span class="material-symbols-rounded text-3xl text-white">

                smart_display

            </span>

        </div>

        <div>

            <h2 class="text-3xl font-bold">

                Recommended Video

            </h2>

            <p class="mt-1 text-[#948979]">

                Watch this before attempting the practice problems.

            </p>

        </div>

    </div>

    <div
        id="youtube-player"
        class="aspect-video w-full overflow-hidden rounded-2xl shadow-lg">

    </div>

</section>

<% } %>

<div class="mt-12 flex flex-wrap items-center justify-between gap-5">

    <% if(chapterIndex>0){ %>

    <a
        href="/course/<%= course._id %>/chapter/<%= moduleIndex %>/<%= Number(chapterIndex)-1 %>"
        class="inline-flex items-center gap-2 rounded-2xl border border-[#393E46] bg-white px-6 py-3 font-semibold text-[#393E46] transition hover:bg-[#393E46] hover:text-white">

        <span class="material-symbols-rounded">

            arrow_back

        </span>

        Previous

    </a>

    <% }else{ %>

    <div></div>

    <% } %>

    <% if(!chapter.completed){ %>

    <form
        action="/course/<%= course._id %>/chapter/<%= moduleIndex %>/<%= chapterIndex %>/complete"
        method="POST">

        <button
            class="inline-flex items-center gap-2 rounded-full bg-[#393E46] px-10 py-4 text-lg font-semibold text-white shadow-lg transition-all duration-300 hover:-translate-y-1 hover:bg-[#222831] hover:shadow-xl">

            <span class="material-symbols-rounded">

                check_circle

            </span>

            Mark Chapter Completed

        </button>

    </form>

    <% }else{ %>

    <div
        class="inline-flex items-center gap-2 rounded-full bg-green-100 px-8 py-4 font-semibold text-green-700">

        <span class="material-symbols-rounded">

            check_circle

        </span>

        Chapter Completed

    </div>

    <% } %>

    <% if(chapterIndex<module.chapters.length-1){ %>

    <a
        href="/course/<%= course._id %>/chapter/<%= moduleIndex %>/<%= Number(chapterIndex)+1 %>"
        class="inline-flex items-center gap-2 rounded-2xl border border-[#393E46] bg-white px-6 py-3 font-semibold text-[#393E46] transition hover:bg-[#393E46] hover:text-white">

        Next

        <span class="material-symbols-rounded">

            arrow_forward

        </span>

    </a>

    <% }else{ %>

    <div></div>

    <% } %>

</div>
</div>

<aside class="hidden xl:block">

    <div class="sticky top-8 rounded-3xl border border-[#948979]/25 bg-[#F7F3EC] p-6 shadow-sm">

        <h3 class="text-xl font-bold text-[#222831]">

            Chapter Contents

        </h3>

        <div class="mt-6 space-y-3">

            <a
                href="#lesson"
                class="flex items-center gap-3 rounded-xl px-4 py-3 transition hover:bg-[#DFD0B8]">

                <span class="material-symbols-rounded">

                    menu_book

                </span>

                Lesson

            </a>

            <% if(chapter.practiceQuestions.length){ %>

            <a
                href="#practice"
                class="flex items-center gap-3 rounded-xl px-4 py-3 transition hover:bg-[#DFD0B8]">

                <span class="material-symbols-rounded">

                    assignment

                </span>

                Practice

            </a>

            <% } %>

            <% if(chapter.youtubeVideo){ %>

            <a
                href="#video"
                class="flex items-center gap-3 rounded-xl px-4 py-3 transition hover:bg-[#DFD0B8]">

                <span class="material-symbols-rounded">

                    smart_display

                </span>

                Video

            </a>

            <% } %>

        </div>

    </div>

</aside>

</div>

</div>

</main>

</div>

<!-- YouTube Feedback Popup -->

<div
    id="youtube-feedback-toast"
    class="hidden fixed bottom-6 right-6 z-50 w-96 rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl">

    <div class="flex items-start justify-between">

        <div>

            <h3 class="text-lg font-semibold text-slate-800">

                Was this video helpful?

            </h3>

            <p class="mt-2 text-sm text-slate-500">

                Your feedback helps improve future recommendations.

            </p>

        </div>

        <button
            onclick="closeToast()"
            class="rounded-lg p-1 transition hover:bg-slate-100">

            <span class="material-symbols-rounded">

                close

            </span>

        </button>

    </div>

    <div class="mt-6 flex gap-3">

        <button
            onclick="sendFeedback('LIKE')"
            class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-green-600 py-3 font-semibold text-white transition hover:bg-green-700">

            <span class="material-symbols-rounded">

                thumb_up

            </span>

            Helpful

        </button>

        <button
            onclick="sendFeedback('DISLIKE')"
            class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-red-600 py-3 font-semibold text-white transition hover:bg-red-700">

            <span class="material-symbols-rounded">

                thumb_down

            </span>

            Not Helpful

        </button>

    </div>

</div>

<script>

const courseId = "<%= course._id %>";
const moduleIndex = <%= moduleIndex %>;
const chapterIndex = <%= chapterIndex %>;
const channelName = "<%= chapter.youtubeChannel %>";
const youtubeUrl = "<%= chapter.youtubeVideo %>";

</script>

<script src="https://www.youtube.com/iframe_api"></script>
<script src="/js/youtubePlayer.js"></script>

</body>
</html>