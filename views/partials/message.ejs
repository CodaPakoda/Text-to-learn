
<% if(error){ %>

<div
    id="message-box"
    class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-600">

    <%= error %>

</div>

<% } %>

<% if(success){ %>

<div
    id="message-box"
    class="mb-6 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm font-medium text-green-600">

    <%= success %>

</div>

<% } %>

<script src="/js/message.js"></script>
