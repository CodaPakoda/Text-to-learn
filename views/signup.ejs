<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Sign Up | TextToLearn</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <script>

        tailwind.config = {

            theme: {

                extend: {

                    fontFamily: {

                        sans: ["Inter", "sans-serif"]

                    }

                }

            }

        }

    </script>

</head>

<body class="bg-[#F8F8F6] font-sans">

<div class="min-h-screen flex items-center justify-center px-6">

    <div class="w-full max-w-md">

        <div class="text-center">

            <h1 class="mt-8 text-3xl font-bold text-[#222831]">

                Create Account

            </h1>

            <p class="mt-3 text-[#6B7280]">

                Start your AI-powered learning journey.

            </p>

        </div>

        <div class="mt-10 rounded-3xl border border-[#E8E4DC] bg-white p-8 shadow-lg">

            <%- include("partials/message") %>

            <form
                action="/auth/signup"
                method="POST"
                class="space-y-6">

                <div>

                    <label
                        for="username"
                        class="mb-2 block text-sm font-medium text-[#393E46]">

                        Username

                    </label>

                    <input
                        id="username"
                        type="text"
                        name="username"
                        placeholder="Enter your username"
                        autocomplete="username"
                        required
                        class="w-full rounded-xl border border-[#E8E4DC] px-4 py-3 outline-none transition-all duration-300 focus:border-[#948979] focus:ring-2 focus:ring-[#DFD0B8]">

                </div>

                <div>

                    <label
                        for="email"
                        class="mb-2 block text-sm font-medium text-[#393E46]">

                        Email Address

                    </label>

                    <input
                        id="email"
                        type="email"
                        name="email"
                        placeholder="Enter your email"
                        autocomplete="email"
                        required
                        class="w-full rounded-xl border border-[#E8E4DC] px-4 py-3 outline-none transition-all duration-300 focus:border-[#948979] focus:ring-2 focus:ring-[#DFD0B8]">

                </div>

                <div>

                    <label
                        for="password"
                        class="mb-2 block text-sm font-medium text-[#393E46]">

                        Password

                    </label>

                    <input
                        id="password"
                        type="password"
                        name="password"
                        placeholder="Create a password"
                        autocomplete="new-password"
                        required
                        class="w-full rounded-xl border border-[#E8E4DC] px-4 py-3 outline-none transition-all duration-300 focus:border-[#948979] focus:ring-2 focus:ring-[#DFD0B8]">

                </div>

                <button
                    type="submit"
                    class="w-full rounded-xl bg-[#222831] py-3 font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-[#393E46]">

                    Create Account

                </button>

            </form>

            <p class="mt-8 text-center text-sm text-[#6B7280]">

                Already have an account?

                <a
                    href="/auth/login"
                    class="font-semibold text-[#948979] transition hover:text-[#7D7467] hover:underline">

                    Login

                </a>

            </p>

        </div>

        <div class="mt-8 text-center">

            <a
                href="/"
                class="text-sm text-[#6B7280] transition hover:text-[#948979]">

                ← Back to Home

            </a>

        </div>

    </div>

</div>

</body>

</html>